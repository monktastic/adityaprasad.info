---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="Aditya Prasad">
  <div class="hero-wrapper">
    <section class="hero">
      <h1>Aditya Prasad</h1>
      <p class="tagline">
        Writing at the intersection of contemplative practice,
        philosophy, and mathematics.
      </p>
      <div class="hero-rule" aria-hidden="true"></div>
    </section>
  </div>

  <div class="home">
    <section class="intro">
      <p>
        I'm interested in the deep structure of experience — what contemplative
        traditions have mapped for millennia and what formal systems can
        illuminate about that terrain. My work explores how rigorous inquiry and
        meditative insight can inform each other, without collapsing the
        distinction between them.
      </p>
    </section>

    {essays.length > 0 && (
      <section class="recent">
        <h2>Recent essays</h2>
        <ul class="essay-list">
          {essays.map((essay) => (
            <li>
              <a href={`/essays/${essay.id}`}>
                <span class="essay-title">{essay.data.title}</span>
                <span class="essay-date">
                  {essay.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                  })}
                </span>
              </a>
              <p class="essay-desc">{essay.data.description}</p>
            </li>
          ))}
        </ul>
        <a href="/essays" class="all-link">All essays &rarr;</a>
      </section>
    )}
  </div>
</Base>

<style>
  .hero-wrapper {
    position: relative;
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .hero h1 {
    font-size: 3.2rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: #e0dbd5;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-align: center;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-rule {
    height: 2px;
    background: var(--color-accent);
    margin: var(--space-md) auto 0;
    opacity: 0.6;
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    text-align: center;
  }


  .home {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md) var(--space-xl);
    background: rgba(10, 10, 10, 0.55);
    border-radius: 4px;
  }

  .intro {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .intro p {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .recent {
    padding-top: var(--space-lg);
  }

  .recent h2 {
    font-size: 1rem;
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-md);
    margin-top: 0;
  }

  .essay-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .essay-list li a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-sm);
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .essay-list li a:hover {
    color: var(--color-accent);
  }

  .essay-title {
    font-size: 1.2rem;
    font-weight: 500;
  }

  .essay-date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .essay-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.3em;
    margin-bottom: 0;
  }

  .all-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .all-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 2.4rem;
    }

    .essay-list li a {
      flex-direction: column;
      gap: 0.2em;
    }
  }
</style>

<script>
  function syncRuleWidth() {
    const h1 = document.querySelector('.hero h1');
    const rule = document.querySelector('.hero-rule');
    if (h1 && rule) rule.style.width = h1.offsetWidth + 'px';
  }
  syncRuleWidth();
  window.addEventListener('resize', syncRuleWidth);
</script>
