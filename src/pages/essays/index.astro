---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Essays — Aditya Prasad" description="Essays on contemplative practice, philosophy, and mathematics.">
  <div class="essays-page">
    <header>
      <h1>Essays</h1>
    </header>

    {essays.length === 0 ? (
      <p class="empty">Nothing here yet. Check back soon.</p>
    ) : (
      <ul class="essay-list">
        {essays.map((essay) => (
          <li>
            <a href={`/essays/${essay.id}`}>
              <div class="essay-info">
                <span class="essay-title">{essay.data.title}</span>
                <p class="essay-desc">{essay.data.description}</p>
              </div>
              <time datetime={essay.data.date.toISOString()}>
                {essay.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .essays-page {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md) var(--space-xl);
  }

  header {
    margin-bottom: var(--space-lg);
  }

  .empty {
    color: var(--color-text-muted);
  }

  .essay-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .essay-list li {
    border-bottom: 1px solid var(--color-border);
  }

  .essay-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .essay-list li a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .essay-list li a:hover {
    color: var(--color-accent);
  }

  .essay-title {
    font-size: 1.2rem;
    font-weight: 500;
    display: block;
  }

  .essay-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin-top: 0.3em;
    margin-bottom: 0;
    line-height: 1.5;
  }

  time {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.3em;
  }

  @media (max-width: 600px) {
    .essay-list li a {
      flex-direction: column;
      gap: 0.3em;
    }
  }
</style>
