---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
}

const { title, description, date, updated } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${title} — Aditya Prasad`} description={description}>
  <article class="essay">
    <header class="essay-header">
      <h1>{title}</h1>
      <div class="essay-meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {updated && (
          <span class="updated">
            Updated <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
          </span>
        )}
      </div>
    </header>
    <div class="essay-body">
      <slot />
    </div>
  </article>
</Base>

<style>
  .essay {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md) var(--space-xl);
    background: rgba(10, 10, 10, 0.75);
    border-radius: 4px;
  }

  .essay-header {
    margin-bottom: var(--space-lg);
  }

  .essay-header h1 {
    margin-bottom: var(--space-sm);
  }

  .essay-meta {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-sm);
  }

  .updated {
    color: var(--color-text-dim);
  }

  .essay-body {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .essay-body :global(ul),
  .essay-body :global(ol) {
    margin-bottom: 1.4em;
    padding-left: 1.5em;
  }

  .essay-body :global(li) {
    margin-bottom: 0.4em;
  }
</style>
